{
  "name": "tsx-script",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@11.1.0+sha512.0c44e842e5686b2c061a81adda8b2258bd8818e9704b2cf2c63d56b931a7b2e910092e085027003b96ca3911ab56a07f6df5abaed2be9925034cdd686a535b14",
  "description": "add a script mode to the tsx typescript runner",
  "author": "magicdawn",
  "license": "MIT",
  "homepage": "https://github.com/magicdawn/tsx-script#readme",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/magicdawn/tsx-script.git"
  },
  "bugs": {
    "url": "https://github.com/magicdawn/tsx-script/issues"
  },
  "keywords": [
    "tsx",
    "ts-node"
  ],
  "bin": {
    "tsx-script": "./dist/cli.js",
    "tsxs": "./dist/cli.js"
  },
  "files": [
    "./dist/"
  ],
  "scripts": {
    "test": "vitest run",
    "prepare": "husky",
    "test:dev": "vitest",
    "test-cover": "vitest run --coverage",
    "dev": "tsdown --watch",
    "build": "tsdown",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "dependencies": {
    "es-toolkit": "^1.45.1",
    "execa": "^9.6.1",
    "fs-extra": "^11.3.4",
    "get-tsconfig": "^4.14.0",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@magicdawn/eslint-config": "^1.6.2",
    "@magicdawn/prettier-config": "^0.1.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^24.12.2",
    "@types/yargs": "^17.0.35",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tsdown": "^0.21.8",
    "typescript": "^6.0.2",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "*.{?(c|m)(j|t)s?(x),json,y?(a)ml}": [
      "eslint --fix",
      "prettier --write"
    ],
    "!*.{?(c|m)(j|t)s?(x),json,y?(a)ml}": [
      "prettier --write --ignore-unknown"
    ]
  },
  "prettier": "@magicdawn/prettier-config"
}
